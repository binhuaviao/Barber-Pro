rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isServerTimestamp(field) {
      return field == request.time;
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return (data.get('email', '') is string && data.get('email', '').size() <= 256) &&
             (data.get('displayName', '') is string && data.get('displayName', '').size() <= 128) &&
             (data.get('revenueGoal', 0) is number || data.get('revenue_goal', 0) is number);
    }

    function isValidClient(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 128 &&
             (data.get('phone', '') is string && data.get('phone', '').size() <= 32) &&
             (data.get('email', '') is string && data.get('email', '').size() <= 256) &&
             (data.get('notes', '') is string && data.get('notes', '').size() <= 1000);
    }

    function isValidService(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 128 &&
             (data.price is number && data.price >= 0) &&
             (data.get('duration', 0) is number);
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 128 &&
             data.price is number && data.price >= 0 &&
             (data.get('stock', 0) is number);
    }

    function isValidAppointment(data) {
      return (data.get('clientId', '') is string || data.get('client_id', '') is string) &&
             (data.get('clientName', '') is string || data.get('client_name', '') is string) &&
             data.date is timestamp &&
             data.status in ['pending', 'concluido', 'cancelado'] &&
             data.price is number && data.price >= 0;
    }

    function isValidFinancialEntry(data) {
      return data.type in ['entrada', 'saida'] &&
             data.amount is number && data.amount >= 0 &&
             data.date is timestamp &&
             (data.get('description', '') is string && data.get('description', '').size() <= 500) &&
             (data.get('category', '') is string && data.get('category', '').size() <= 128) &&
             (data.get('referenceId', '') is string || data.get('reference_id', '') is string || 
              data.get('referenceId', null) == null || data.get('reference_id', null) == null);
    }

    // --- Match Groups ---

    match /system/connection_test {
      allow read: if true;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email', 'revenueGoal', 'revenue_goal', 'updatedAt']);

      match /clientes/{clientId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(clientId) && isValidClient(incoming());
        allow update: if isOwner(userId) && isValidClient(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'email', 'notes', 'updatedAt']);
        allow delete: if isOwner(userId);
      }

      match /servicos/{serviceId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(serviceId) && isValidService(incoming());
        allow update: if isOwner(userId) && isValidService(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'price', 'duration', 'updatedAt']);
        allow delete: if isOwner(userId);
      }

      match /produtos/{productId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(productId) && isValidProduct(incoming());
        allow update: if isOwner(userId) && isValidProduct(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'price', 'stock', 'updatedAt']);
        allow delete: if isOwner(userId);
      }

      match /agendamentos/{appointmentId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(appointmentId) && isValidAppointment(incoming());
        allow update: if isOwner(userId) && isValidAppointment(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['status', 'date', 'price', 'serviceId', 'serviceName', 'service_id', 'service_name', 'clientId', 'clientName', 'client_id', 'client_name', 'updatedAt']);
        allow delete: if isOwner(userId);
      }

      match /financeiro/{entryId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(entryId) && isValidFinancialEntry(incoming());
        allow update: if isOwner(userId) && isValidFinancialEntry(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['type', 'amount', 'date', 'description', 'category', 'referenceId', 'reference_id', 'updatedAt']);
        allow delete: if isOwner(userId);
      }
    }
  }
}
